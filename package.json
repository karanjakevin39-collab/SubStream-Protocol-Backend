{
  "name": "substream-backend",
  "version": "1.0.0",
  "description": "API for SubStream Protocol",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:ws": "nest start",
    "start:ws:dev": "nest start --watch",
    "start:ws:debug": "nest start --debug --watch",
    "start:ws:prod": "node dist/main",
    "dev": "nodemon index.js",
    "build": "nest build",
    "test": "jest",
    "test:ws": "jest --config ./test/jest-ws.config.js",
    "test:ws:watch": "jest --config ./test/jest-ws.config.js --watch",
    "test:ws:cov": "jest --config ./test/jest-ws.config.js --coverage",
    "test:ws:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:ws:e2e": "jest --config ./test/jest-e2e.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "archiver": "^6.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.8.1",
    "express": "^5.2.1",
    "form-data": "^4.0.0",
    "ioredis": "^5.10.1",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "web3.storage": "^4.5.4",
    "xml": "^1.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
